# ── Go Core connection ────────────────────────────────────────────────────────
# Base URL of the running noderouter-core instance.
CORE_URL=http://localhost:8080

# UUID assigned by Go Core when you registered this node via /api/admin/nodes/add.
# Leave blank to rely on Go Core's pull-based health checks (recommended for
# docker_internal and localhost nodes that are directly reachable).
# Set this for edge_node / cloud nodes behind firewalls that need push heartbeats.
NODE_ID=

# ── Runner settings ───────────────────────────────────────────────────────────
# Port the runner HTTP server listens on.
PORT=8000

# Directory containing app packages or flat .py files.
APPS_DIR=./apps

# How often (seconds) the runner pushes a heartbeat to Go Core.
# Only used when NODE_ID is set.
HEARTBEAT_INTERVAL=30

# ── Async channel (PostgreSQL LISTEN/NOTIFY) ──────────────────────────────────
# Direct PostgreSQL DSN used by the runner for the async job queue.
# Must point to the same PostgreSQL instance used by Go Core.
# Required to enable the async channel; leave blank to run sync-only.
DATABASE_URL=postgresql://user:password@localhost:5432/noderouter

# Max concurrent threads dispatching async jobs.
# Each dispatched job runs in its own isolated subprocess (ProcessPoolExecutor).
ASYNC_MAX_WORKERS=4
